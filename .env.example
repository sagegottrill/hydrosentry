# Copy to `.env.local` for local `vercel dev` (never commit real keys).
# In production, set the same variables in the Vercel project → Settings → Environment Variables.

# Supabase (existing)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Supabase — server-only (Vercel function reads alert_sms_recipients)
# SUPABASE_URL=https://xxxx.supabase.co   (or rely on VITE_SUPABASE_URL if set for the same project)
# SUPABASE_SERVICE_ROLE_KEY=              (never expose in VITE_*)

# Termii — server-only (used by /api/send-termii-sms on Vercel)
TERMII_API_KEY=
TERMII_BASE_URL=https://v3.api.termii.com
TERMII_SENDER_ID=N-Alert

# Optional: full URL to the SMS API when testing (default is same-origin /api/send-termii-sms)
# VITE_SMS_API_URL=http://localhost:3000/api/send-termii-sms
